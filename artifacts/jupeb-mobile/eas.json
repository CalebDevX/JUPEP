{
  "cli": {
    "version": ">= 13.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "preview": {
      "android": {
        "buildType": "apk",
        "credentialsSource": "local"
      },
      "channel": "preview",
      "env": {
        "npm_config_legacy_peer_deps": "true",
        "EXPO_PUBLIC_API_URL": "https://jupep-production-c683.up.railway.app/api"
      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle",
        "credentialsSource": "local"
      },
      "ios": {
        "resourceClass": "m-medium"
      },
      "channel": "production",
      "credentialsSource": "local",
      "env": {
        "npm_config_legacy_peer_deps": "true",
        "EXPO_PUBLIC_API_URL": "https://jupep-production-c683.up.railway.app/api"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
