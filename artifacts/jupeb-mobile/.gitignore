# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native — managed by EAS via CNG (expo prebuild)
# EAS Build regenerates android/ and ios/ from app.config.js on every build.
# Do NOT commit these — they will be out of date when package versions change.
/android
/ios
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# typescript
*.tsbuildinfo
